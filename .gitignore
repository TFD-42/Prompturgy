# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Runtime data (user-specific, not shared)
settings.json
memory/sessions.json
outputs/*
!outputs/.gitkeep

