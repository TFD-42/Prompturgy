*.pcap
*.pcapng
*.cap
tcpdump*.txt
tcpdump*.log

# Generated launchers (created by installer, platform-specific)
Pro_Prompt
Pro_Prompt.bat

# Scratch / working files — never commit
f1.json
f2.json
scratch/
tmp/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets / credentials
.env
.env.*
*.key
*.pem
credentials*
secrets*
*_secret*
id_rsa*
.netrc

